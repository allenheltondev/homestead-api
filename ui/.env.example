# Copy to .env.local and fill in. Vite reads .env.local during dev.

# Base URL of the deployed Homestead API (no trailing slash), including the
# `v1` stage path. Example: https://abc123.execute-api.us-east-1.amazonaws.com/v1
VITE_API_BASE_URL=

# AWS region the Cognito user pool lives in.
VITE_AWS_REGION=us-east-1

# Cognito User Pool id. The shared rsc-core RSCUserPool the Homestead API
# authorizer trusts.
VITE_USER_POOL_ID=

# App Client id for this dashboard. Must have:
# - Authentication flow: USER_PASSWORD_AUTH (or ALLOW_USER_SRP_AUTH)
# - No client secret (public client)
# The dashboard signs users in inline rather than redirecting to the
# Cognito Hosted UI.
VITE_USER_POOL_CLIENT_ID=
